# otel-collector-config.yaml
# Generated by Ansible podman_deploy role from templates/otel-collector-config.yaml.j2.
# To use a fully static configuration instead, set otel_collector_custom_config: true
# and edit app/opentelemetry/custom-otel-collector-config.yaml directly.

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318
  prometheus:
    config:
      scrape_configs:
        - job_name: weaviate
          scrape_interval: 15s
          static_configs:
            - targets: ['weaviate:2112']

processors:
  batch:
    timeout: 10s
    send_batch_size: 1024
  cumulativetodelta:

exporters:
  debug:
{% if otel_collector_dynatrace_export | bool %}
  otlphttp/dynatrace:
    endpoint: "{{ otel_collector_dynatrace_endpoint }}"
    headers:
      Authorization: "Api-Token {{ otel_collector_dynatrace_token }}"
{% endif %}

service:
  telemetry:
    logs:
      level: "info"
      encoding: "json"
    metrics:
      level: "detailed"
      readers:
        - periodic:
            interval: 10000
            timeout: 5000
            exporter:
              otlp:
                protocol: http/protobuf
                temporality_preference: delta
                endpoint: "http://localhost:4318/v1/metrics"
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters:
        - debug
{% if otel_collector_dynatrace_export | bool and otel_collector_dynatrace_export_traces | bool %}
        - otlphttp/dynatrace
{% endif %}
    metrics:
      receivers: [otlp, prometheus]
      processors: [cumulativetodelta, batch]
      exporters:
        - debug
{% if otel_collector_dynatrace_export | bool and otel_collector_dynatrace_export_metrics | bool %}
        - otlphttp/dynatrace
{% endif %}
    logs:
      receivers: [otlp]
      processors: [batch]
      exporters:
        - debug
{% if otel_collector_dynatrace_export | bool and otel_collector_dynatrace_export_logs | bool %}
        - otlphttp/dynatrace
{% endif %}
