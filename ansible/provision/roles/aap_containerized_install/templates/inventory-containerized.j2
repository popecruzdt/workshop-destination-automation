# Generated by provision role: aap_containerized_install
# Target topology: growth all-in-one (containerized)

[automationgateway]
{{ aap_private_hostname }} ansible_connection=local ansible_user={{ aap_install_user }}

[automationcontroller]
{{ aap_private_hostname }} ansible_connection=local ansible_user={{ aap_install_user }}

[automationhub]
{{ aap_private_hostname }} ansible_connection=local ansible_user={{ aap_install_user }}

[automationeda]
{{ aap_private_hostname }} ansible_connection=local ansible_user={{ aap_install_user }}

[redis]
{{ aap_private_hostname }} ansible_connection=local ansible_user={{ aap_install_user }}

[database]
{{ aap_private_hostname }} ansible_connection=local ansible_user={{ aap_install_user }}

[all:vars]
postgresql_admin_username={{ aap_postgresql_admin_username }}
postgresql_admin_password={{ aap_postgresql_admin_password }}
bundle_install={{ aap_bundle_install | ternary('true', 'false') }}
{% if aap_bundle_install %}
bundle_dir={{ aap_bundle_dir }}
{% endif %}
redis_mode={{ aap_redis_mode }}

aap_base_dir={{ aap_base_dir }}
postgres_data_dir={{ aap_postgres_data_dir }}
controller_data_dir={{ aap_controller_data_dir }}
automationhub_data_dir={{ aap_hub_data_dir }}
redis_data_dir={{ aap_redis_data_dir }}

gateway_hostname={{ aap_public_hostname }}
gateway_api_url=https://{{ aap_public_hostname }}

gateway_admin_password={{ aap_admin_password }}
gateway_pg_host={{ aap_db_host }}
gateway_pg_database=ansiblegateway
gateway_pg_username=admin
gateway_pg_password={{ aap_admin_password }}
gateway_pg_is_external=false

controller_admin_password={{ aap_admin_password }}
controller_pg_host={{ aap_db_host }}
controller_pg_database=ansiblecontroller
controller_pg_username=admin
controller_pg_password={{ aap_admin_password }}
controller_pg_is_external=false

controller_web_workers=1
controller_task_workers=2
controller_max_concurrent_jobs=5

hub_admin_password={{ aap_admin_password }}
hub_pg_host={{ aap_db_host }}
hub_pg_database=ansiblehub
hub_pg_username=admin
hub_pg_password={{ aap_admin_password }}
hub_pg_is_external=false
hub_install=true
hub_seed={{ aap_hub_seed | ternary('true', 'false') }}
{% if aap_hub_seed_collections | length > 0 %}
hub_seed_collections={{ aap_hub_seed_collections }}
{% else %}
hub_seed_collections=[]
{% endif %}

eda_admin_password={{ aap_admin_password }}
eda_pg_host={{ aap_db_host }}
eda_pg_database=ansibleeda
eda_pg_username=admin
eda_pg_password={{ aap_admin_password }}
eda_pg_is_external=false
