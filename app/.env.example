# AI Travel Advisor example configuration for host-based runs.
# Copy to .env for manual Python execution. In Podman Compose, service-level
# environment variables in podman-compose.yml override these values.

# Application settings
SERVICE_NAME=ai-travel-advisor
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8082
LOG_LEVEL=INFO

# Ollama settings
OLLAMA_ENDPOINT=http://localhost:11434
AI_MODEL=gemma2:2b
AI_EMBEDDING_MODEL=nomic-embed-text
AI_TEMPERATURE=0.7

# Weaviate settings
WEAVIATE_ENDPOINT=localhost
WEAVIATE_PORT=8080
WEAVIATE_SCHEME=http

# RAG settings
MAX_PROMPT_LENGTH=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=3
FORCE_REINDEX=false
MIN_KB_OBJECTS=450

# Paths
DESTINATIONS_PATH=destinations
PUBLIC_PATH=public
RAG_PROMPT_PATH=prompts/rag_instructions.txt

# OpenTelemetry and OpenLLMetry
OPENLLMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ai-travel-advisor
TRACELOOP_TRACE_CONTENT=false
