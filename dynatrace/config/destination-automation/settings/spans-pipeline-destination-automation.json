{
  "metadataList": [],
  "customId": "pipeline_destination-automation_5356",
  "displayName": "destination-automation",
  "processing": {
    "processors": [
      {
        "id": "processor_Gen_AI_System_7039",
        "type": "dql",
        "matcher": "isNotNull(gen_ai.system)",
        "description": "Gen AI System",
        "enabled": true,
        "dql": {
          "script": "fieldsAdd gen_ai.system = lower(gen_ai.system)"
        }
      },
      {
        "id": "processor_Gen_AI_Temperature_7040",
        "type": "dql",
        "matcher": "isNotNull(traceloop.association.properties.ls_temperature)",
        "description": "Gen AI Temperature",
        "enabled": true,
        "dql": {
          "script": "fieldsAdd gen_ai.request.temperature = traceloop.association.properties.ls_temperature"
        }
      }
    ]
  },
  "securityContext": {
    "processors": []
  },
  "costAllocation": {
    "processors": []
  },
