    "processors": []
  },
  "storage": {
    "processors": []
  },
  "smartscapeNodeExtraction": {
    "processors": []
  },
  "smartscapeEdgeExtraction": {
    "processors": []
  },
  "metricExtraction": {
    "processors": [
      {
        "id": "processor_Input_gen_ai.client.token.usage_6625",
        "type": "samplingAwareValueMetric",
        "matcher": "isNotNull(gen_ai.usage.input_tokens) and matchesValue(span.name,\"ChatOllama.chat\") and isNotNull(gen_ai.system)",
        "description": "Input gen_ai.client.token.usage",
        "enabled": true,
        "samplingAwareValueMetric": {
          "metricKey": "gen_ai.client.token.usage",
          "field": "gen_ai.usage.input_tokens",
          "defaultValue": "0",
          "dimensions": [
            {
              "extractionType": "field",
              "sourceFieldName": "dt.cost.product"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.cost.costcenter"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.entity.service"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.entity.host_group"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "gen_ai.token.type",
              "destinationFieldName": "gen_ai.token.type",
              "defaultValue": "input"
            }
          ],
          "sampling": "disabled",
          "aggregation": "disabled",
          "measurement": "field"
        }
      },
      {
        "id": "processor_Output_gen_ai.client.token.usage_4433",
        "type": "samplingAwareValueMetric",
        "matcher": "isNotNull(gen_ai.usage.output_tokens) and matchesValue(span.name,\"ChatOllama.chat\") and isNotNull(gen_ai.system)",
        "description": "Output gen_ai.client.token.usage",
        "enabled": true,
        "samplingAwareValueMetric": {
          "metricKey": "gen_ai.client.token.usage",
          "field": "gen_ai.usage.output_tokens",
          "defaultValue": "0",
          "dimensions": [
            {
              "extractionType": "field",
              "sourceFieldName": "dt.cost.product"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.cost.costcenter"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.entity.service"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.entity.host_group"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "gen_ai.token.type",
              "destinationFieldName": "gen_ai.token.type",
              "defaultValue": "output"
            }
          ],
          "sampling": "disabled",
          "aggregation": "disabled",
          "measurement": "field"
        }
      },
      {
        "id": "processor_gen_ai.client.operation.duration_6725",
        "type": "samplingAwareValueMetric",
        "matcher": "matchesValue(span.name,\"ChatOllama.chat\") and isNotNull(gen_ai.system)",
        "description": "gen_ai.client.operation.duration",
        "enabled": true,
        "samplingAwareValueMetric": {
          "metricKey": "gen_ai.client.operation.duration",
          "dimensions": [
            {
              "extractionType": "field",
              "sourceFieldName": "dt.host_group.id"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.cost.product"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.cost.costcenter"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.entity.host_group"
            },
            {
              "extractionType": "field",
              "sourceFieldName": "dt.entity.service"
            }
          ],
          "sampling": "enabled",
          "aggregation": "enabled",
          "measurement": "duration"
        }
      }
    ]
