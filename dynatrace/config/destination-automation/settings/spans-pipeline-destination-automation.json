  "davis": {
    "processors": []
  },
  "dataExtraction": {
    "processors": [
      {
        "id": "processor_Gen_AI_-_Ollama_9105",
        "type": "bizevent",
        "matcher": "matchesValue(span.name,\"ChatOllama.chat\") and isNotNull(gen_ai.system)",
        "description": "Gen AI - Ollama",
        "enabled": true,
        "bizevent": {
          "eventType": {
            "type": "constant",
            "constant": "gen_ai.llm"
          },
          "eventProvider": {
            "type": "constant",
            "constant": "openllmetry.ollama"
          },
          "fieldExtraction": {
            "type": "includeAll"
          }
        }
      },
      {
        "id": "processor_Gen_AI_-_Weaviate_4800",
        "type": "bizevent",
        "matcher": "matchesValue(db.system,\"weaviate\") and isNotNull(weaviate.collection)",
        "description": "Gen AI - Weaviate",
        "enabled": true,
        "bizevent": {
          "eventType": {
            "type": "constant",
            "constant": "gen_ai.vectordb"
          },
          "eventProvider": {
            "type": "constant",
            "constant": "openllmetry.weaviate"
          },
          "fieldExtraction": {
            "type": "includeAll"
          }
        }
